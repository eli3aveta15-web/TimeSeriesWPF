<Window x:Class="TimeSeriesWPF.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="420" Width="420"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Регистрация" 
                   FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Имя пользователя:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="2" x:Name="txtUsername" 
                 AutomationProperties.AutomationId="txtUsername"
                 Height="30" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="3" Text="Пароль:" Margin="0,0,0,5"/>
        <PasswordBox Grid.Row="4" x:Name="txtPassword" 
                     AutomationProperties.AutomationId="txtPassword"
                     Height="30" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="5" Text="Роль:" Margin="0,0,0,5"/>
        <ComboBox Grid.Row="6" x:Name="cmbRole" 
                  AutomationProperties.AutomationId="cmbRole"
                  Height="30" Margin="0,0,0,20">
            <ComboBoxItem Content="Viewer" IsSelected="True"/>
            <ComboBoxItem Content="Analyst"/>
            <ComboBoxItem Content="Admin"/>
        </ComboBox>

        <StackPanel Grid.Row="7" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Зарегистрироваться" Width="150" Height="35" Margin="0,0,15,0"
                    Click="BtnRegister_Click"/>
            <Button Content="Назад" Width="110" Height="35"
                    Click="BtnBack_Click"/>
        </StackPanel>

        <TextBlock x:Name="txtError" 
                   AutomationProperties.AutomationId="txtError"
                   Foreground="Red" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Bottom" 
                   Visibility="Collapsed"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>
    </Grid>
</Window>
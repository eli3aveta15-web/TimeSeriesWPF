<Window x:Class="TimeSeriesWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="320" Width="420"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Вход в систему" 
                   FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,25"/>

        <TextBlock Grid.Row="1" Text="Имя пользователя:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="2" x:Name="txtUsername" 
                 AutomationProperties.AutomationId="txtUsername"
                 Height="30" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="3" Text="Пароль:" Margin="0,0,0,5"/>
        <PasswordBox Grid.Row="4" x:Name="txtPassword" 
                     AutomationProperties.AutomationId="txtPassword"
                     Height="30" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" 
                    HorizontalAlignment="Center" VerticalAlignment="Top">
            <Button Content="Войти" Width="120" Height="35" Margin="0,0,15,0"
                    Click="BtnLogin_Click"/>
            <Button Content="Зарегистрироваться" Width="150" Height="35"
                    Click="BtnRegister_Click"/>
        </StackPanel>

        <TextBlock x:Name="txtError" 
                   AutomationProperties.AutomationId="txtError"
                   Foreground="Red" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Bottom" 
                   Visibility="Collapsed"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>
    </Grid>
</Window>